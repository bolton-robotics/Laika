<?xml version="1.0"?>
<launch>

    <!-- LiDAR parameters -->
    <arg name="serial_port" default="/dev/serial/by-path/platform-fd500000.pcie-pci-0000:01:00.0-usb-0:1.3:1.0-port0"/>
    <arg name="frame_id" default="laser_frame"/>

    <!-- Start LiDAR driver -->
    <node pkg="rplidar_ros" exec="rplidar_composition" name="rplidar_node" output="screen">
        <param name="serial_port" value="$(var serial_port)"/>
        <param name="frame_id" value="$(var frame_id)"/>
        <param name="angle_compensate" value="true"/>
        <param name="scan_mode" value="standard"/>
    </node>

</launch>
